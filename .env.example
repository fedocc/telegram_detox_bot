AITUNNEL_BASE_URL=https://api.aitunnel.ru/v1/
AITUNNEL_MODEL=claude-haiku-4.5
AITUNNEL_API_KEY=

EMAIL_TRANSPORT=gmail_api
GMAIL_OAUTH_CLIENT_SECRET_PATH=secrets/google_oauth_client.json
GMAIL_OAUTH_TOKEN_PATH=data/gmail_oauth_token.json
EMAIL_FROM=
EMAIL_TO=

# Optional legacy SMTP mode. Set EMAIL_TRANSPORT=smtp to use these.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_TLS_MODE=ssl
SMTP_USERNAME=
SMTP_PASSWORD=

TG_API_ID=
TG_API_HASH=
TG_PHONE=
TG_SESSION_PATH=data/telegram_digest.session

DATABASE_URL=sqlite:///data/telegram_digest.db
TIMEZONE=Europe/Moscow
DIGEST_TIME=20:30
RAW_RETENTION_DAYS=14
DIGEST_RETENTION_DAYS=90

BIRTHDAY_REMINDERS_ENABLED=false
BIRTHDAY_POLL_INTERVAL_HOURS=6
BIRTHDAY_REMINDER_TIME=09:00
BIRTHDAY_LOOKAHEAD_DAYS=1
BIRTHDAY_MANUAL_PATH=data/birthdays.json

P0_CLASSIFY_PRIVATE_TEXT=true
P0_CLASSIFY_ALL_GROUPS=false
P0_CLASSIFY_MENTIONS=true
P0_CLASSIFY_REPLIES=true
P0_CLASSIFY_WATCHLIST_CHATS=true
P0_WATCHLIST_CHAT_IDS=
P0_WATCHLIST_KEYWORDS=
P0_MENTION_USERNAMES=me,fedornikonov
P0_TRUSTED_SENDER_IDS=
P0_MAX_CONTEXT_MESSAGES=5
P0_MAX_MESSAGE_CHARS=1000
P0_MAX_LLM_CALLS_PER_HOUR=100
P0_BACKFILL_IMMEDIATE_WINDOW_MINUTES=30

BACKFILL_ENABLED=true
BACKFILL_HOURS=24
BACKFILL_MAX_MESSAGES_PER_CHAT=200
BACKFILL_MAX_TOTAL_MESSAGES=5000
