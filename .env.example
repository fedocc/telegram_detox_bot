AITUNNEL_BASE_URL=https://api.aitunnel.ru/v1/
AITUNNEL_MODEL=claude-haiku-4.5
AITUNNEL_API_KEY=

EMAIL_TRANSPORT=gmail_api
GMAIL_OAUTH_CLIENT_SECRET_PATH=secrets/google_oauth_client.json
GMAIL_OAUTH_TOKEN_PATH=data/gmail_oauth_token.json
EMAIL_FROM=
EMAIL_TO=

# Optional legacy SMTP mode. Set EMAIL_TRANSPORT=smtp to use these.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_TLS_MODE=ssl
SMTP_USERNAME=
SMTP_PASSWORD=

TG_API_ID=
TG_API_HASH=
TG_PHONE=
TG_SESSION_PATH=data/telegram_digest.session

DATABASE_URL=sqlite:///data/telegram_digest.db
TIMEZONE=Europe/Moscow
DIGEST_TIME=20:30
RAW_RETENTION_DAYS=14
DIGEST_RETENTION_DAYS=90
